  "item": [
    {
      "name": "Testing Collection/Array",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// P1-02: Schema Deep Validation\r",
              "pm.test(\"P1-02 | Schema Validation: Response is a valid Array of Posts\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    \r",
              "    // Cek sampel data pertama untuk validasi kontrak (Contract Testing)\r",
              "    const schema = jsonData[0];\r",
              "    pm.expect(schema).to.have.all.keys('userId', 'id', 'title', 'body');\r",
              "    pm.expect(schema.id).to.be.a('number');\r",
              "    pm.expect(schema.title).to.be.a('string');\r",
              "});\r",
              "\r",
              "// P1-03: Data Integrity (Uniqueness)\r",
              "pm.test(\"P1-03 | Data Integrity: ID must be unique\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const ids = jsonData.map(item => item.id);\r",
              "    const uniqueIds = new Set(ids);\r",
              "    pm.expect(uniqueIds.size).to.eql(ids.length); // Memastikan tidak ada ID ganda\r",
              "});\r",
              "\r",
              "// E1-03: Header Analysis\r",
              "pm.test(\"E1-03 | Content-Type is JSON with UTF-8\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
