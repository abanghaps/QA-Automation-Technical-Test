          "script": {
            "exec": [
              "// P3-01 & P3-02: Creation and Persistence\r",
              "pm.test(\"P3-01 | Resource Created Successfully\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"P3-04 | Data Reflection: Request body matches Response body\", function () {\r",
              "    const requestData = JSON.parse(pm.request.body.raw);\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData.title).to.eql(requestData.title);\r",
              "    pm.expect(responseData.body).to.eql(requestData.body);\r",
              "});\r",
              "\r",
              "// E3-04: ID Persistence (Mocking behavior)\r",
              "pm.test(\"E3-04 | Server returns unique ID 101\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(101);\r",
              "});"
            ],
